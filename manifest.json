{
  "manifest_version": 3,
  "name": "Focus Reader - ADHD Bionic Reading",
  "version": "1.1.0",
  "description": "Bolds the leading half of every word to create reading anchors that help with focus and attention. Works on web pages and on imported PDF/text files.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "Focus Reader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/bionic.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; worker-src 'self'; child-src 'self'"
  }
}
